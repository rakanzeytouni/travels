<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Main</title>
</head>
<style>
        :root {
            --primary: #ffcc00;
            --dark: #1a1a1a;
            --glass: rgba(255, 255, 255, 0.15);
        }

        body {
            margin: 0;
            font-family: 'Poppins', sans-serif;
            background-color: #f0f2f5;
            overflow-x: hidden; /* Tamen ma ysir fi scroll lal yamin */
        }

        /* --- HEADER & NAVIGATION --- */
        .navbar-container {
            position: absolute;
            top: 15px;
            width: 100%;
            display: flex;
            justify-content: center;
            z-index: 1000;
        }

        header {
            height: 60px;
            width: 90%;
            display: flex;
            background: var(--glass);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
            border-radius: 50px;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .logo { 
            font-weight: 600; 
            font-size: 1.1rem; 
            color: white; 
            text-transform: uppercase;
         }

        /* Added align-items: center here to fix the vertical drop */
        nav ul { 
            display: flex; 
            gap: 20px; 
            list-style: none; 
            margin: 0; 
            padding: 0; 
            align-items: center; 
        }

        nav a { text-decoration: none; color: white; font-size: 0.85rem; }

        .btn-ticket {
            background: var(--primary);
            color: black !important;
            padding: 8px 15px;
            border-radius: 20px;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
        }

        /* --- HERO SECTION --- */
        .hero {
            height: 450px;
            background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.2)), 
                        url("Gemini_Generated_Image_lhlpp9lhlpp9lhlp.png");
            background-size: cover;
            background-position: center;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            text-align: center;
            padding: 0 20px;
        }

        .hero h1 { font-size: 2.5rem; margin: 0; }

        /* --- SEARCH BAR (RESPONSIVE) --- */
        .search-container {
            width: 85%;
            max-width: 1000px;
            background: white;
            padding: 25px;
            border-radius: 20px;
            box-shadow: 0 15px 40px rgba(0,0,0,0.1);
            margin: -50px auto 50px;
            display: grid;
            grid-template-columns: repeat(3, 1fr) auto; /* Desktop Layout */
            gap: 15px;
            position: relative;
            z-index: 10;
        }

        .input-group { display: flex; flex-direction: column; }
        .input-group label { font-size: 0.75rem; font-weight: 600; margin-bottom: 5px; color: #666; }
        .input-group input { padding: 10px; border: 1px solid #ddd; border-radius: 8px; font-size: 0.9rem; }

        .btn-search {
            background: var(--dark);
            color: white;
            border: none;
            padding: 0 30px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            height: 45px;
            align-self: flex-end;
        }

        /* --- DESTINATIONS --- */
        .section-title { text-align: center; margin: 20px 0; }
        
        .destinations {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
            width: 85%;
            margin: 0 auto 50px;
        }

        .card { background: white; border-radius: 15px; overflow: hidden; box-shadow: 0 5px 15px rgba(0,0,0,0.05); }
        .card-img { height: 180px; background: #ddd; width: 100%; object-fit: cover; }
        .card-info { padding: 15px; }

        /* --- MEDIA QUERIES (Lal Mobile) --- */
        @media (max-width: 768px) {
            header { width: 95%; padding: 0 15px; }
            .logo { font-size: 0.9rem; }
            nav ul { gap: 10px; }
            nav a { font-size: 0.75rem; }
            .btn-ticket { padding: 6px 12px; }

            .hero h1 { font-size: 1.8rem; }
            
            /* Search container bi sir 1 column bel mobile */
            .search-container {
                grid-template-columns: 1fr;
                margin-top: -30px;
                width: 90%;
                padding: 20px;
            }

            .btn-search {
                width: 100%;
                margin-top: 10px;
            }
        }
    </style>
<body>

<div id="offlineMessage" style="
    display: none;
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    min-width: 300px;
    padding: 16px 24px;
    background: rgba(220, 38, 38, 0.95);
    backdrop-filter: blur(8px);
    color: white;
    border-radius: 12px;
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    display: flex;
    align-items: center;
    gap: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
">
    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M18.36 6.64a9 9 0 010 12.72M15.54 9.46a5 5 0 010 7.08M4 11l2 2 2-2M1 1l22 22"></path>
    </svg>
    <span style="font-size: 14px; letter-spacing: 0.3px;">
        Connection lost. Please check your internet.
    </span>
</div>

    <div class="navbar-container">
        <header> 
            <div class="logo">zen-escape</div>
            <nav>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/offers">Offers</a></li>
                    <li>
                        <form action="/regester" style="margin: 0; padding: 0; display: flex;">
                            <button type="submit" class="btn-ticket" style="border: none; cursor: pointer; font-family: inherit; font-size: 0.85rem; ">Sign In</button>
                        </form>
                    </li>
                    <li><a href="#" class="btn-ticket">My Booking</a></li>
                </ul>
            </nav>      
        </header>
    </div>

    <section class="hero">
        <h1>Where to next?</h1>
        <p>Book your flights at the best rates.</p>
    </section>

    <div class="search-container">
        <div class="input-group">
            <label>From</label>
            <input type="text" placeholder="Origin">
        </div>
        <div class="input-group">
            <label>To</label>
            <input type="text" placeholder="Destination">
        </div>
        <div class="input-group">
            <label>Date</label>
            <input type="date">
        </div>
        <button class="btn-search">Search</button>
    </div>

    <div class="section-title">
        <h2>Popular Deals</h2>
    </div>

    <section class="destinations">
        <div class="card">
            <div class="card-img" style="background: url('https://images.unsplash.com/photo-1502602898657-3e91760cbb34?auto=format&fit=crop&w=400&q=80') center/cover;"></div>
            <div class="card-info">
                <h3>Paris, France</h3>
                <p>Starting from <b style="color:#2ecc71">$299</b></p>
            </div>
        </div>
        <div class="card">
            <div class="card-img" style="background: url('https://images.unsplash.com/photo-1512453979798-5ea266f8880c?auto=format&fit=crop&w=400&q=80') center/cover;"></div>
            <div class="card-info">
                <h3>Dubai, UAE</h3>
                <p>Starting from <b style="color:#2ecc71">$150</b></p>
            </div>
        </div>
    </section>

    <script src="/js/offline.js"></script>

</body>
</html>