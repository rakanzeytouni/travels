<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <link rel="stylesheet" href="/css/main.css">
    <title>Main</title>
</head>
<body>

<div id="offlineMessage" style="
    display: none;
    position: fixed;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 9999;
    min-width: 300px;
    padding: 16px 24px;
    background: rgba(220, 38, 38, 0.95);
    backdrop-filter: blur(8px);
    color: white;
    border-radius: 12px;
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    display: flex;
    align-items: center;
    gap: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
">
    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M18.36 6.64a9 9 0 010 12.72M15.54 9.46a5 5 0 010 7.08M4 11l2 2 2-2M1 1l22 22"></path>
    </svg>
    <span style="font-size: 14px; letter-spacing: 0.3px;">
        Connection lost. Please check your internet.
    </span>
</div>

    <div class="navbar-container">
        <header> 
            <div class="logo">zen-escape</div>
            <nav>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/offers">Offers</a></li>
                    <li>
              <% if (typeof user !== 'undefined' && user) { %>
      <!-- User is logged in -->
      <li>
        <a href="/profile" class="btn-ticket">
          <i class="fas fa-user"></i> <%= user.name %>
        </a>
      </li>
      <li>
        <form action="/auth/logout" method="POST" style="margin: 0; padding: 0; display: flex;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn-ticket" style="background: red; color: white !important; border: none; cursor: pointer;">
            <i class="fas fa-sign-out-alt"></i> Logout
          </button>
        </form>
      </li>
    <% } else { %>
      <!-- User is NOT logged in -->
      <li>
        <form action="/auth/login" style="margin: 0; padding: 0; display: flex;">
          <button type="submit" class="btn-ticket">Sign In</button>
        </form>
      </li>
       <a href="/profile" class="btn-ticket"> your profile</a>
    <% } %>
  </ul>
</nav>
    
        </header>
    </div>

    <section class="hero">
        <h1>Where to next?</h1>
        <p>Book your flights at the best rates.</p>
    </section>

    <div class="search-container">
        <div class="input-group">
            <label>From</label>
            <input type="text" placeholder="Origin">
        </div>
        <div class="input-group">
            <label>To</label>
            <input type="text" placeholder="Destination">
        </div>
        <div class="input-group">
            <label>Date</label>
            <input type="date">
        </div>
        <button class="btn-search">Search</button>
    </div>

    <div class="section-title">
        <h2>Popular Deals</h2>
    </div>

    <section class="destinations">
        <div class="card">
            <div class="card-img" style="background: url('https://images.unsplash.com/photo-1502602898657-3e91760cbb34?auto=format&fit=crop&w=400&q=80') center/cover;"></div>
            <div class="card-info">
                <h3>Paris, France</h3>
                <p>Starting from <b style="color:#2ecc71">$299</b></p>
            </div>
        </div>
        <div class="card">
            <div class="card-img" style="background: url('https://images.unsplash.com/photo-1512453979798-5ea266f8880c?auto=format&fit=crop&w=400&q=80') center/cover;"></div>
            <div class="card-info">
                <h3>Dubai, UAE</h3>
                <p>Starting from <b style="color:#2ecc71">$150</b></p>
            </div>
        </div>
    </section>

    <script src="/js/offline.js"></script>

</body>
</html>