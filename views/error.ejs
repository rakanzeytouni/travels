<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error</title>
  <style>
    body {
      font-family: system-ui, sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      margin: 0;
      background: #f8f9fa;
      color: #333;
    }
    .container {
      text-align: center;
      padding: 2rem;
      background: white;
      border-radius: 12px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
      max-width: 500px;
    }
    h1 { color: #e74c3c; font-size: 3rem; margin: 0; }
    p { font-size: 1.1rem; margin: 1rem 0; }
    a {
      display: inline-block;
      margin-top: 1rem;
      color: #3498db;
      text-decoration: none;
      font-weight: 500;
    }
    a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="container">
    <h1>⚠️ Oops!</h1>
    <p><%= message || "Something went wrong" %></p>
    <a href="/">← Go back home</a>
  </div>
</body>
</html>