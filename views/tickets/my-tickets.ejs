<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Tickets</title>
    <style>
        :root {
            --bg: #f8fafc;
            --card-bg: #ffffff;
            --text-main: #0f172a;
            --text-sub: #64748b;
            --border: #e2e8f0;
            --radius: 12px;
            --shadow: 0 4px 6px -1px rgba(0,0,0,0.08);
            --primary: #2563eb;
            --pending: #f59e0b;
            --accepted: #22c55e;
            --rejected: #ef4444;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background: var(--bg);
            color: var(--text-main);
            padding: 2rem 1rem;
            line-height: 1.5;
        }

        .container { max-width: 800px; margin: 0 auto; }
        h1 { margin-bottom: 1.5rem; font-size: 1.8rem; }

        .ticket-list { display: flex; flex-direction: column; gap: 1rem; }

        .ticket-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1.25rem;
            box-shadow: var(--shadow);
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .ticket-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 16px -4px rgba(0,0,0,0.1);
        }

        .route { font-size: 1.2rem; font-weight: 600; }
        .meta { display: flex; flex-wrap: wrap; gap: 1rem; color: var(--text-sub); font-size: 0.9rem; }
        .meta span { display: flex; align-items: center; gap: 0.3rem; }

        .status-badge {
            display: inline-block;
            padding: 0.35rem 0.8rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: capitalize;
            width: fit-content;
        }

        .status-badge.pending { background: #fef3c7; color: #92400e; }
        .status-badge.accepted { background: #dcfce7; color: #166534; }
        .status-badge.rejected { background: #fee2e2; color: #991b1b; }

        .actions { display: flex; justify-content: flex-end; margin-top: 0.5rem; }
        .btn-view {
            background: var(--primary);
            color: white;
            text-decoration: none;
            padding: 0.6rem 1.2rem;
            border-radius: 8px;
            font-weight: 500;
            font-size: 0.9rem;
            transition: background 0.2s ease;
        }
        .btn-view:hover { background: #1d4ed8; }

        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
            color: var(--text-sub);
            background: var(--card-bg);
            border-radius: var(--radius);
            border: 1px dashed var(--border);
        }

        @media (max-width: 640px) {
            .meta { flex-direction: column; gap: 0.4rem; }
            .ticket-card { padding: 1rem; }
        }
    </style>
</head>
<body>
    <div class="container">
        <h1> My Tickets</h1>

        <% if (bookings && bookings.length > 0) { %>
            <div class="ticket-list">
                <% bookings.forEach(booking => { %>
                    <div class="ticket-card">
                        <div class="route">
                            <%= booking.trip ? booking.trip.from : 'Unknown' %> → <%= booking.trip ? booking.trip.to : 'Unknown' %>
                        </div>
                        
                        <div class="meta">
                            <span>📅 <%= booking.trip ? new Date(booking.trip.date).toLocaleDateString() : 'N/A' %></span>
                            <span>✈️ <%= booking.trip ? booking.trip.airline : 'N/A' %></span>
                            <span>💺 <%= booking.seats %> Seat(s)</span>
                            <span>💰 $<%= booking.totalPrice %></span>
                        </div>

                        <div class="status-badge <%= booking.status %>">
                            <%= booking.status %>
                        </div>

                        <div class="actions">
                            <a href="/tickets/<%= booking._id %>" class="btn-view">View Ticket Details</a>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="empty-state">
                <p style="font-size: 1.1rem; margin-bottom: 0.5rem;">📭 No tickets yet</p>
                <p>Book a trip to see it here.</p>
            </div>
        <% } %>
    </div>
</body>
</html>