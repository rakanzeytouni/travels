<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile - Zen Escape</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/profile.css">
    
</head>
<body>

    <!-- ==================== NAVBAR ==================== -->
    <div class="navbar-container">
        <header> 
            <a href="/" class="logo">zen-escape</a>
            
            <!-- Desktop Navigation -->
        <!-- Desktop Navigation -->
<nav class="nav-desktop">
  <ul>
    <li><a href="/">Home</a></li>
    <li><a href="/offers">Offers</a></li>
    
    <% if (typeof user !== 'undefined' && user) { %>
      <!-- User is logged in -->
      <li>
        <a href="/profile" class="btn-ticket">
          <i class="fas fa-user"></i> <%= user.name %>
        </a>
      </li>
      <li>
        <form action="/auth/logout" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn-ticket" >
            <i class="fas fa-sign-out-alt"></i> Logout
          </button>
        </form>
      </li>
    <% } else { %>
      <!-- User is NOT logged in -->
      <li>
        <form action="/auth/login" >
          <button type="submit" class="btn-ticket">Sign In</button>
        </form>
      </li>
      <li><a href="/regester" class="btn-ticket" >Register</a></li>
    <% } %>
  </ul>
</nav>
            
            <!-- Hamburger Menu Button -->
            <div class="hamburger" id="hamburger" aria-label="Toggle menu">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </header>
    </div>

    <!-- Mobile Navigation Drawer -->
    <nav class="nav-mobile" id="navMobile">
        <a href="/"><i class="fas fa-home"></i> Home</a>
        <a href="/offers"><i class="fas fa-tag"></i> Offers</a>
        <a href="#"><i class="fas fa-ticket-alt"></i> My Booking</a>
        <a href="/profile" class="active"><i class="fas fa-user"></i> Profile</a>
        <form action="/regester" >
            <button type="submit" class="btn-ticket" >Sign In</button>
        </form>
    </nav>

    <!-- Overlay for mobile menu -->
    <div class="overlay" id="overlay"></div>

    <!-- ==================== PROFILE HERO ==================== -->
    <section class="profile-hero">
        <div class="profile-header-content">
            <div class="profile-avatar-container">
                <img src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=400&q=80" alt="Profile" class="profile-avatar">
                <div class="verified-badge"><i class="fas fa-check"></i></div>
            </div>
            <div class="profile-info">
  <% if (typeof user !== 'undefined' && user) { %>
    <!-- User is logged in -->
    <h1><%= user.name %></h1>
    <p class="location"><i class="fas fa-map-marker-alt"></i> <%= user.location || 'Cairo, Egypt' %></p>
    <div class="member-badge">
      <i class="fas fa-crown"></i> <%= user.membership || 'Gold Member' %>
    </div>
  <% } else { %>
    <!-- User is NOT logged in -->
    <h1>👋 Welcome!</h1>
    <p class="location"><i class="fas fa-info-circle"></i> Please sign in to view your profile</p>
    <div style="margin-top: 20px;">
      <a href="/auth/login" class="btn-primary" >
        <i class="fas fa-sign-in-alt"></i> Sign In Now
      </a>
    </div>
  <% } %>
</div>
    </section>

    <!-- ==================== MAIN CONTENT ==================== -->
    <div class="profile-container">
        
        <!-- Stats Cards -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(255, 204, 0, 0.2);">
                    <i class="fas fa-plane" style="color: var(--primary);"></i>
                </div>
                <div class="stat-info">
                    <h3>12</h3>
                    <p>Trips Taken</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(46, 204, 113, 0.2);">
                    <i class="fas fa-map-marked-alt" style="color: #2ecc71;"></i>
                </div>
                <div class="stat-info">
                    <h3>8</h3>
                    <p>Countries</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(52, 152, 219, 0.2);">
                    <i class="fas fa-star" style="color: #3498db;"></i>
                </div>
                <div class="stat-info">
                    <h3>2,450</h3>
                    <p>Points</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(155, 89, 182, 0.2);">
                    <i class="fas fa-heart" style="color: #9b59b6;"></i>
                </div>
                <div class="stat-info">
                    <h3>5</h3>
                    <p>Saved Trips</p>
                </div>
            </div>
        </div>

        <!-- Two Column Layout -->
        <div class="profile-grid">
            
            <!-- Left Column - Personal Info -->
            <div class="profile-sidebar">
                <div class="glass-card">
                    <h3><i class="fas fa-user"></i> Personal Information</h3>
                    <div class="info-group">
                        <form action="">
                        <label>Name</label>
                        <p></p>
                    </div>
                    <div class="info-group">
                        <label>Email</label>
                        <p></p>
                    </div>
                    <div class="info-group">
                        <label>Phone</label>
                        <p></p>
                    </div>
                    <div class="info-group">
                        <label>Date of Birth</label>
                        <p></p>
                    </div>
                    <button class="btn-edit"><i class="fas fa-edit"></i> Edit Profile</button>
                </div>
            </form>

                <div class="glass-card">
                    <h3><i class="fas fa-passport"></i> Travel Documents</h3>
                    <div class="document-item">
                        <i class="fas fa-id-card"></i>
                        <div>
                            <p>Passport</p>
                            <small>Expires: Dec 2028</small>
                        </div>
                        <i class="fas fa-check-circle" style="color: #2ecc71;"></i>
                    </div>
                    <div class="document-item">
                        <i class="fas fa-id-card"></i>
                        <div>
                            <p>National ID</p>
                            <small>Verified</small>
                        </div>
                        <i class="fas fa-check-circle" style="color: #2ecc71;"></i>
                    </div>
                </div>
            </div>

            <!-- Right Column - Bookings -->
            <div class="profile-main">
                
                <!-- Upcoming Trips -->
                <div class="section-header">
                    <h2><i class="fas fa-calendar-check"></i> Upcoming Trips</h2>
                    <a href="#" class="view-all">View All</a>
                </div>

                <div class="booking-card">
                    <div class="booking-image" style="background: url('https://images.unsplash.com/photo-1502602898657-3e91760cbb34?auto=format&fit=crop&w=400&q=80') center/cover;"></div>
                    <div class="booking-details">
                        <div class="booking-header">
                            <h3>Paris, France</h3>
                            <span class="status confirmed"><i class="fas fa-check"></i> Confirmed</span>
                        </div>
                        <div class="booking-info">
                            <div class="info-item">
                                <i class="fas fa-plane-departure"></i>
                                <div>
                                    <small>Departure</small>
                                    <p>CAI → CDG<br>Oct 15, 2024 - 14:30</p>
                                </div>
                            </div>
                            <div class="info-item">
                                <i class="fas fa-plane-arrival"></i>
                                <div>
                                    <small>Return</small>
                                    <p>CDG → CAI<br>Oct 22, 2024 - 18:45</p>
                                </div>
                            </div>
                        </div>
                        <div class="booking-actions">
                            <button class="btn-primary"><i class="fas fa-ticket-alt"></i> View Ticket</button>
                            <button class="btn-secondary"><i class="fas fa-download"></i> Invoice</button>
                        </div>
                    </div>
                </div>

                <div class="booking-card">
                    <div class="booking-image" style="background: url('https://images.unsplash.com/photo-1512453979798-5ea266f8880c?auto=format&fit=crop&w=400&q=80') center/cover;"></div>
                    <div class="booking-details">
                        <div class="booking-header">
                            <h3>Dubai, UAE</h3>
                            <span class="status pending"><i class="fas fa-clock"></i> Pending</span>
                        </div>
                        <div class="booking-info">
                            <div class="info-item">
                                <i class="fas fa-plane-departure"></i>
                                <div>
                                    <small>Departure</small>
                                    <p>CAI → DXB<br>Nov 05, 2024 - 10:15</p>
                                </div>
                            </div>
                            <div class="info-item">
                                <i class="fas fa-plane-arrival"></i>
                                <div>
                                    <small>Return</small>
                                    <p>DXB → CAI<br>Nov 12, 2024 - 22:30</p>
                                </div>
                            </div>
                        </div>
                        <div class="booking-actions">
                            <button class="btn-primary"><i class="fas fa-ticket-alt"></i> View Ticket</button>
                            <button class="btn-danger"><i class="fas fa-times"></i> Cancel</button>
                        </div>
                    </div>
                </div>

                <!-- Past Trips -->
                <div class="section-header" style="margin-top: 40px;">
                    <h2><i class="fas fa-history"></i> Past Trips</h2>
                    <a href="#" class="view-all">View All</a>
                </div>

                <div class="booking-card past">
                    <div class="booking-image" style="background: url('https://images.unsplash.com/photo-1533105079780-92b9be482077?auto=format&fit=crop&w=400&q=80') center/cover; opacity: 0.7;"></div>
                    <div class="booking-details">
                        <div class="booking-header">
                            <h3>Santorini, Greece</h3>
                            <span class="status completed"><i class="fas fa-check-double"></i> Completed</span>
                        </div>
                        <div class="booking-info">
                            <div class="info-item">
                                <i class="fas fa-calendar"></i>
                                <div>
                                    <small>Travel Date</small>
                                    <p>Aug 10 - Aug 17, 2024</p>
                                </div>
                            </div>
                        </div>
                        <div class="booking-actions">
                            <button class="btn-secondary"><i class="fas fa-star"></i> Write Review</button>
                            <button class="btn-secondary"><i class="fas fa-redo"></i> Rebook</button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
   <script src="/js/menu.js"></script>
</body>
</html>