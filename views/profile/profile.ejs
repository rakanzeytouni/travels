<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile - Zen Escape</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --primary: #ffcc00;
            --dark: #1a1a1a;
            --glass: rgba(255, 255, 255, 0.15);
            --success: #2ecc71;
            --warning: #f39c12;
            --danger: #e74c3c;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #f2f2a4db 0%, #89ca95 50%,rgb(240, 153, 91) 100%);
            min-height: 100vh;
            padding-bottom: 50px;
            overflow-x: hidden;
        }

        /* ==================== NAVBAR ==================== */
        .navbar-container {
            position: fixed;
            top: 15px;
            width: 100%;
            display: flex;
            justify-content: center;
            z-index: 1000;
            padding: 0 15px;
        }

        header { 
            height: 60px;
            width: 90%;
            max-width: 1200px;
            display: flex;
            background: var(--glass);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
            border-radius: 50px;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .logo { 
            font-weight: 600; 
            font-size: 1.1rem; 
            color: white; 
            text-transform: uppercase;
            text-decoration: none;
        }

        /* Desktop Navigation */
        .nav-desktop {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .nav-desktop ul { 
            display: flex; 
            gap: 20px; 
            list-style: none; 
            margin: 0; 
            padding: 0; 
            align-items: center; 
        }

        .nav-desktop a { 
            text-decoration: none; 
            color: white; 
            font-size: 0.85rem; 
            transition: 0.3s;
            font-weight: 500;
        }

        .nav-desktop a:hover {
            color: var(--primary);
        }

        .btn-ticket {
            background: var(--primary);
            color: black !important;
            padding: 8px 15px;
            border-radius: 20px;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            transition: transform 0.3s;
            border: none;
            cursor: pointer;
            font-family: inherit;
            font-size: 0.85rem;
        }

        .btn-ticket:hover {
            transform: translateY(-2px);
        }

        /* Hamburger Menu Button */
        .hamburger {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
            padding: 5px;
            z-index: 1001;
        }

        .hamburger span {
            width: 25px;
            height: 3px;
            background: white;
            border-radius: 3px;
            transition: 0.3s;
        }

        .hamburger.active span:nth-child(1) {
            transform: rotate(45deg) translate(5px, 5px);
        }

        .hamburger.active span:nth-child(2) {
            opacity: 0;
        }

        .hamburger.active span:nth-child(3) {
            transform: rotate(-45deg) translate(5px, -5px);
        }

        /* Mobile Navigation Drawer */
        .nav-mobile {
            position: fixed;
            top: 0;
            right: -100%;
            width: 280px;
            height: 100vh;
            background: rgba(26, 26, 26, 0.98);
            backdrop-filter: blur(20px);
            padding: 80px 25px 30px;
            transition: right 0.3s ease;
            z-index: 999;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .nav-mobile.active {
            right: 0;
        }

        .nav-mobile a {
            color: white;
            text-decoration: none;
            font-size: 1.1rem;
            padding: 15px 20px;
            border-radius: 12px;
            transition: 0.3s;
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 500;
        }

        .nav-mobile a:hover,
        .nav-mobile a.active {
            background: var(--glass);
            color: var(--primary);
        }

        .nav-mobile .btn-ticket {
            width: 100%;
            text-align: center;
            margin-top: 10px;
        }

        /* Overlay */
        .overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.5);
            opacity: 0;
            visibility: hidden;
            transition: 0.3s;
            z-index: 998;
        }

        .overlay.active {
            opacity: 1;
            visibility: visible;
        }

        /* ==================== PROFILE HERO ==================== */
        .profile-hero {
            margin-top: 100px;
            padding: 60px 20px 40px;
            display: flex;
            justify-content: center;
        }

        .profile-header-content {
            text-align: center;
            color: white;
            max-width: 600px;
        }

        .profile-avatar-container {
            position: relative;
            display: inline-block;
            margin-bottom: 20px;
        }

        .profile-avatar {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
            border: 5px solid rgba(255, 255, 255, 0.3);
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

        .verified-badge {
            position: absolute;
            bottom: 10px;
            right: 10px;
            background: var(--primary);
            color: var(--dark);
            width: 35px;
            height: 35px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 3px solid white;
            font-size: 0.9rem;
        }

        .profile-info h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
            font-weight: 700;
        }

        .profile-info .location {
            font-size: 1.1rem;
            opacity: 0.9;
            margin-bottom: 15px;
        }

        .member-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(255, 204, 0, 0.2);
            padding: 8px 20px;
            border-radius: 25px;
            font-weight: 600;
            font-size: 0.9rem;
            border: 1px solid rgba(255, 204, 0, 0.3);
        }

        .member-badge i {
            color: var(--primary);
        }

        /* ==================== MAIN CONTAINER ==================== */
        .profile-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 40px 20px;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }

        .stat-card {
            background: white;
            padding: 20px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            gap: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: transform 0.3s;
        }

        .stat-card:hover {
            transform: translateY(-5px);
        }

        .stat-icon {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            flex-shrink: 0;
        }

        .stat-info h3 {
            font-size: 1.8rem;
            color: var(--dark);
            margin-bottom: 3px;
            line-height: 1;
        }

        .stat-info p {
            color: #666;
            font-size: 0.85rem;
        }

        /* Two Column Layout */
        .profile-grid {
            display: grid;
            grid-template-columns: 350px 1fr;
            gap: 30px;
        }

        /* Glass Cards */
        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 25px;
            margin-bottom: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .glass-card h3 {
            color: var(--dark);
            margin-bottom: 20px;
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .glass-card h3 i {
            color: var(--primary);
        }

        .info-group {
            margin-bottom: 20px;
        }

        .info-group label {
            display: block;
            font-size: 0.85rem;
            color: #666;
            margin-bottom: 5px;
            font-weight: 500;
        }

        .info-group p {
            color: var(--dark);
            font-weight: 600;
            font-size: 1rem;
            word-break: break-word;
        }

        .btn-edit {
            width: 100%;
            padding: 12px;
            background: var(--dark);
            color: white;
            border: none;
            border-radius: 10px;
            font-family: inherit;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-edit:hover {
            background: var(--primary);
            color: var(--dark);
        }

        /* Documents */
        .document-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 15px;
            background: rgba(255, 204, 0, 0.1);
            border-radius: 12px;
            margin-bottom: 10px;
        }

        .document-item i:first-child {
            font-size: 1.5rem;
            color: var(--primary);
            flex-shrink: 0;
        }

        .document-item div {
            flex: 1;
            min-width: 0;
        }

        .document-item p {
            font-weight: 600;
            color: var(--dark);
            font-size: 0.95rem;
        }

        .document-item small {
            color: #666;
            font-size: 0.8rem;
        }

        /* Profile Main Content */
        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            flex-wrap: wrap;
            gap: 10px;
        }

        .section-header h2 {
            color: white;
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .section-header h2 i {
            color: var(--primary);
        }

        .view-all {
            color: white;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: 0.3s;
        }

        .view-all:hover {
            color: var(--primary);
        }

        /* Booking Cards */
        .booking-card {
            background: white;
            border-radius: 20px;
            overflow: hidden;
            display: flex;
            margin-bottom: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: transform 0.3s;
        }

        .booking-card:hover {
            transform: translateY(-5px);
        }

        .booking-card.past {
            opacity: 0.85;
        }

        .booking-image {
            width: 250px;
            min-height: 200px;
            flex-shrink: 0;
        }

        .booking-details {
            padding: 25px;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .booking-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 20px;
            gap: 15px;
            flex-wrap: wrap;
        }

        .booking-header h3 {
            color: var(--dark);
            font-size: 1.4rem;
            font-weight: 700;
        }

        .status {
            padding: 6px 15px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
        }

        .status.confirmed {
            background: rgba(46, 204, 113, 0.15);
            color: #27ae60;
        }

        .status.pending {
            background: rgba(243, 156, 18, 0.15);
            color: #d68910;
        }

        .status.completed {
            background: rgba(52, 152, 219, 0.15);
            color: #2980b9;
        }

        .booking-info {
            display: flex;
            gap: 25px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }

        .info-item {
            display: flex;
            gap: 12px;
            flex: 1;
            min-width: 200px;
        }

        .info-item i {
            font-size: 1.3rem;
            color: var(--primary);
            margin-top: 3px;
            flex-shrink: 0;
        }

        .info-item small {
            display: block;
            color: #666;
            font-size: 0.8rem;
            margin-bottom: 4px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .info-item p {
            color: var(--dark);
            font-weight: 600;
            font-size: 0.95rem;
            line-height: 1.4;
        }

        .booking-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .btn-primary, .btn-secondary, .btn-danger {
            padding: 10px 18px;
            border: none;
            border-radius: 10px;
            font-family: inherit;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.85rem;
        }

        .btn-primary {
            background: var(--primary);
            color: var(--dark);
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 204, 0, 0.3);
        }

        .btn-secondary {
            background: #f0f0f0;
            color: var(--dark);
        }

        .btn-secondary:hover {
            background: #e0e0e0;
        }

        .btn-danger {
            background: rgba(231, 76, 60, 0.1);
            color: var(--danger);
        }

        .btn-danger:hover {
            background: rgba(231, 76, 60, 0.2);
        }

        /* ==================== RESPONSIVE ==================== */
        
        /* Tablet & Mobile */
        @media (max-width: 968px) {
            .profile-grid {
                grid-template-columns: 1fr;
            }
            
            .booking-card {
                flex-direction: column;
            }
            
            .booking-image {
                width: 100%;
                height: 180px;
            }
            
            .booking-info {
                flex-direction: column;
                gap: 15px;
            }
            
            .info-item {
                min-width: 100%;
            }
        }

        /* Mobile */
        @media (max-width: 768px) {
            /* Navbar */
            header {
                width: 95%;
                padding: 0 15px;
            }
            
            .nav-desktop {
                display: none;
            }
            
            .hamburger {
                display: flex;
            }
            
            /* Profile Hero */
            .profile-hero {
                margin-top: 90px;
                padding: 40px 15px 30px;
            }
            
            .profile-avatar {
                width: 120px;
                height: 120px;
            }
            
            .verified-badge {
                width: 30px;
                height: 30px;
                font-size: 0.8rem;
            }
            
            .profile-info h1 {
                font-size: 1.8rem;
            }
            
            .profile-info .location {
                font-size: 1rem;
            }
            
            .member-badge {
                padding: 6px 15px;
                font-size: 0.85rem;
            }
            
            /* Stats */
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 15px;
            }
            
            .stat-card {
                padding: 15px;
                gap: 12px;
            }
            
            .stat-icon {
                width: 45px;
                height: 45px;
                font-size: 1.1rem;
            }
            
            .stat-info h3 {
                font-size: 1.5rem;
            }
            
            .stat-info p {
                font-size: 0.8rem;
            }
            
            /* Cards */
            .glass-card {
                padding: 20px;
            }
            
            .glass-card h3 {
                font-size: 1.1rem;
            }
            
            .info-group p {
                font-size: 0.95rem;
            }
            
            .document-item {
                padding: 12px;
                gap: 12px;
            }
            
            .document-item i:first-child {
                font-size: 1.3rem;
            }
            
            .document-item p {
                font-size: 0.9rem;
            }
            
            /* Booking Cards */
            .section-header h2 {
                font-size: 1.3rem;
            }
            
            .booking-header h3 {
                font-size: 1.3rem;
            }
            
            .booking-details {
                padding: 20px;
            }
            
            .booking-actions {
                flex-direction: column;
            }
            
            .btn-primary, .btn-secondary, .btn-danger {
                width: 100%;
                justify-content: center;
            }
            
            /* Mobile Nav */
            .nav-mobile {
                width: 85%;
                max-width: 320px;
                padding: 70px 20px 30px;
            }
            
            .nav-mobile a {
                font-size: 1rem;
                padding: 12px 15px;
            }
        }

        /* Small Mobile */
        @media (max-width: 480px) {
            .profile-info h1 {
                font-size: 1.5rem;
            }
            
            .stats-grid {
                grid-template-columns: 1fr 1fr;
            }
            
            .stat-info h3 {
                font-size: 1.4rem;
            }
            
            .booking-image {
                height: 160px;
            }
            
            .info-item small {
                font-size: 0.75rem;
            }
            
            .info-item p {
                font-size: 0.9rem;
            }
        }

        /* Windows/Desktop specific tweaks */
        @media (min-width: 1200px) {
            .profile-container {
                padding: 50px 30px;
            }
            
            .booking-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 20px 50px rgba(0,0,0,0.15);
            }
        }

        /* Animation for mobile menu */
        @keyframes slideIn {
            from { right: -100%; }
            to { right: 0; }
        }

        .nav-mobile.active {
            animation: slideIn 0.3s ease forwards;
        }
    </style>
</head>
<body>

    <!-- ==================== NAVBAR ==================== -->
    <div class="navbar-container">
        <header> 
            <a href="/" class="logo">zen-escape</a>
            
            <!-- Desktop Navigation -->
        <!-- Desktop Navigation -->
<nav class="nav-desktop">
  <ul>
    <li><a href="/">Home</a></li>
    <li><a href="/offers">Offers</a></li>
    
    <% if (typeof user !== 'undefined' && user) { %>
      <!-- User is logged in -->
      <li>
        <a href="/profile" class="btn-ticket">
          <i class="fas fa-user"></i> <%= user.name %>
        </a>
      </li>
      <li>
        <form action="/auth/logout" method="POST" style="margin: 0; padding: 0; display: flex;">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn-ticket" style="background: var(--danger); color: white !important; border: none; cursor: pointer;">
            <i class="fas fa-sign-out-alt"></i> Logout
          </button>
        </form>
      </li>
    <% } else { %>
      <!-- User is NOT logged in -->
      <li>
        <form action="/auth/login" style="margin: 0; padding: 0; display: flex;">
          <button type="submit" class="btn-ticket">Sign In</button>
        </form>
      </li>
      <li><a href="/regester" class="btn-ticket" style="background: transparent; border: 2px solid var(--primary);">Register</a></li>
    <% } %>
  </ul>
</nav>
            
            <!-- Hamburger Menu Button -->
            <div class="hamburger" id="hamburger" aria-label="Toggle menu">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </header>
    </div>

    <!-- Mobile Navigation Drawer -->
    <nav class="nav-mobile" id="navMobile">
        <a href="/"><i class="fas fa-home"></i> Home</a>
        <a href="/offers"><i class="fas fa-tag"></i> Offers</a>
        <a href="#"><i class="fas fa-ticket-alt"></i> My Booking</a>
        <a href="/profile" class="active"><i class="fas fa-user"></i> Profile</a>
        <form action="/regester" style="margin-top: 10px;">
            <button type="submit" class="btn-ticket" style="width: 100%;">Sign In</button>
        </form>
    </nav>

    <!-- Overlay for mobile menu -->
    <div class="overlay" id="overlay"></div>

    <!-- ==================== PROFILE HERO ==================== -->
    <section class="profile-hero">
        <div class="profile-header-content">
            <div class="profile-avatar-container">
                <img src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=400&q=80" alt="Profile" class="profile-avatar">
                <div class="verified-badge"><i class="fas fa-check"></i></div>
            </div>
            <div class="profile-info">
  <% if (typeof user !== 'undefined' && user) { %>
    <!-- User is logged in -->
    <h1><%= user.name %></h1>
    <p class="location"><i class="fas fa-map-marker-alt"></i> <%= user.location || 'Cairo, Egypt' %></p>
    <div class="member-badge">
      <i class="fas fa-crown"></i> <%= user.membership || 'Gold Member' %>
    </div>
  <% } else { %>
    <!-- User is NOT logged in -->
    <h1>👋 Welcome!</h1>
    <p class="location"><i class="fas fa-info-circle"></i> Please sign in to view your profile</p>
    <div style="margin-top: 20px;">
      <a href="/auth/login" class="btn-primary" style="padding: 12px 30px; border-radius: 25px; text-decoration: none; font-weight: 600;">
        <i class="fas fa-sign-in-alt"></i> Sign In Now
      </a>
    </div>
  <% } %>
</div>
    </section>

    <!-- ==================== MAIN CONTENT ==================== -->
    <div class="profile-container">
        
        <!-- Stats Cards -->
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(255, 204, 0, 0.2);">
                    <i class="fas fa-plane" style="color: var(--primary);"></i>
                </div>
                <div class="stat-info">
                    <h3>12</h3>
                    <p>Trips Taken</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(46, 204, 113, 0.2);">
                    <i class="fas fa-map-marked-alt" style="color: #2ecc71;"></i>
                </div>
                <div class="stat-info">
                    <h3>8</h3>
                    <p>Countries</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(52, 152, 219, 0.2);">
                    <i class="fas fa-star" style="color: #3498db;"></i>
                </div>
                <div class="stat-info">
                    <h3>2,450</h3>
                    <p>Points</p>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(155, 89, 182, 0.2);">
                    <i class="fas fa-heart" style="color: #9b59b6;"></i>
                </div>
                <div class="stat-info">
                    <h3>5</h3>
                    <p>Saved Trips</p>
                </div>
            </div>
        </div>

        <!-- Two Column Layout -->
        <div class="profile-grid">
            
            <!-- Left Column - Personal Info -->
