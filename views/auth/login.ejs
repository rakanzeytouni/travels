<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zen Escape - Login</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            /* لون خلفية دافئ ومريح مستوحى من خلفية اللوغو */
            background: linear-gradient(135deg, #fdf6ec 0%, #f6e3cf 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        #login {
            background: rgba(255, 255, 255, 0.95);
            padding: 2.5rem;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 400px;
            display: flex;
            flex-direction: column;
        }

        /* تنسيق لصورة اللوغو داخل الفورم */
        .logo-container {
            text-align: center;
            margin-bottom: 1rem;
        }

        .logo-container img {
            max-width: 150px;
        }

        h2 {
            text-align: center;
            color: #88847e; /* لون رمادي مستوحى من نص ZEN */
            margin-bottom: 1.5rem;
        }

        input {
            padding: 12px 15px;
            margin-top: 15px;
            border: 1px solid #ddd;
            border-radius: 8px;
            outline: none;
            transition: 0.3s;
            color: #333;
        }

        input:focus {
            /* لون أزرق مستوحى من الغيوم */
            border-color: #3583c7;
            box-shadow: 0 0 5px rgba(53, 131, 199, 0.3);
        }

        .error {
            color: #e74c3c;
            font-size: 0.8rem;
            margin-top: 5px;
            min-height: 1rem;
        }

        button {
            margin-top: 20px;
            padding: 12px;
            /* تدرج لوني برتقالي وزهري من الغيوم */
            background: linear-gradient(135deg, #fca33a 0%, #de4a79 100%);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
            font-size: 1rem;
            transition: 0.3s;
        }

        button:hover {
            /* تدرج لوني زهري وبنفسجي عند التمرير */
            background: linear-gradient(135deg, #de4a79 0%, #855fb1 100%);
        }

        .google-btn {
            text-align: center;
            margin-top: 15px;
            text-decoration: none;
            color: #88847e;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #ddd;
            padding: 10px;
            border-radius: 8px;
            transition: 0.3s;
        }

        .google-btn:hover {
            background: #fdf6ec;
            color: #3583c7;
            border-color: #3583c7;
        }
    </style>
</head>
<body>
    <form id="login" action="/auth/login" method="POST">
        
        <div class="logo-container">
            <img src="https://i.ibb.co/6w21QnC/image.png" alt="Zen Escape Logo">
        </div>

        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      
        <input type="email" name="email" id="email" value="<%=oldInput?.email || '' %>" placeholder="Email">
        <small class="error"><%=errors?.fields || '' %></small>
        <small class="error"><%=errors?.user || '' %></small>
    
        <input type="password" name="password" id="password" placeholder="Password">
        <small class="error" id="passwordError"><%=errors?.password || '' %></small>
        
        <a href="/auth/auth/google" class="google-btn">
            Sign in with Google
        </a>
    
        <button type="submit">Register</button>
    
    </form>
</body>
</html>